{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": [
      "ES2020",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "esnext",
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "jsx": "preserve",
    "allowSyntheticDefaultImports": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "declarationDir": "./dist/types",
    "rootDir": "./lib",
    "paths": {
      "@kit-data-manager/pid-component/dist/*": [
        "../stencil-library/dist/*"
      ]
    }
  },
  "include": [
    "lib"
  ],
  "exclude": [
    "node_modules"
  ]
}
